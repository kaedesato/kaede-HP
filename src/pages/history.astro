---
import Layout from '../layouts/Layout.astro';
import YouTube from '../components/YouTube.astro';
import { historyData } from '../lib/data/historyData';
---

<Layout title="佐藤かえで | History">
  <div class="container mx-auto p-4">
    <h1 class="text-4xl font-bold text-center my-8">History</h1>

    <ul class="timeline timeline-snap-icon max-md:timeline-compact timeline-vertical">
      {historyData.map((event, i) => (
        <li>
          <div class="timeline-middle">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="h-5 w-5 text-primary"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16z"
                clip-rule="evenodd"
              />
            </svg>
          </div>
          <div
            class={`mb-10 ${i % 2 === 0 ? 'timeline-start md:text-end' : 'timeline-end'}`}
          >
            <time class="font-mono italic text-slate-400">{event.date}</time>
            <div class="text-lg font-black text-white">{event.title}</div>
            {event.description && <p class="text-slate-300 mt-2">{event.description}</p>}
            {event.image && <img src={event.image} alt={event.title} class="rounded-lg shadow-xl my-4" />}
            {event.youtubeId && (
              <div class="my-4">
                <YouTube id={event.youtubeId} />
              </div>
            )}
          </div>
          <hr class="bg-primary/20" />
        </li>
      ))}
    </ul>
  </div>
</Layout>
